<Window x:Class="Firepit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:Firepit.Views"
        Title="Firepit"
        Height="700" Width="1180"
        Background="#1A1612"
        WindowStartupLocation="CenterScreen"
        BorderBrush="#332B22"
        BorderThickness="1">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="32"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Caption bar -->
        <Grid Grid.Row="0" Background="#15110D">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Firepit"
                       Foreground="#A89F92"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="12"
                       Margin="14,0,0,0"
                       VerticalAlignment="Center" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinimizeButton"
                        Style="{StaticResource CaptionMinimizeButton}"
                        Click="OnMinimizeClick"
                        ToolTip="Minimize" />
                <Button x:Name="MaxRestoreButton"
                        Style="{StaticResource CaptionMaximizeButton}"
                        Click="OnMaxRestoreClick"
                        ToolTip="Maximize" />
                <Button x:Name="CloseButton"
                        Style="{StaticResource CaptionCloseButton}"
                        Click="OnCloseClick"
                        ToolTip="Close" />
            </StackPanel>
        </Grid>

        <!-- Body (Phase 2 will move tabs into the caption above) -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Menu Grid.Row="0" Background="#15110D" Foreground="#A89F92">
                <MenuItem Header="_Firepit" Foreground="#A89F92">
                    <MenuItem Header="_Settings…" Click="OnSettingsClick" />
                    <Separator />
                    <MenuItem Header="E_xit" Click="OnExitClick" />
                </MenuItem>
            </Menu>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <views:ProjectListView x:Name="ProjectList" Grid.Column="0" />

                <Grid Grid.Column="1">
                    <TextBlock x:Name="EmptyState"
                               Text="The firepit is cold. Gather a project to begin."
                               Foreground="#A89F92"
                               FontFamily="Cascadia Code, Consolas, Courier New"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />

                    <Border x:Name="Toast"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,18"
                            Padding="14,8"
                            CornerRadius="4"
                            Background="#2A211A"
                            BorderBrush="#F5C97B"
                            BorderThickness="1"
                            Visibility="Collapsed"
                            Panel.ZIndex="100">
                        <TextBlock x:Name="ToastText"
                                   Foreground="#E8E2D8"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="12" />
                    </Border>

                    <TabControl x:Name="Tabs"
                                Background="Transparent"
                                BorderThickness="0"
                                Visibility="Collapsed">
                        <TabControl.ItemContainerStyle>
                            <Style TargetType="TabItem">
                                <Setter Property="Foreground" Value="#A89F92" />
                                <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Courier New" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="14,8" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border x:Name="Bd"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    BorderThickness="0,0,0,2"
                                                    BorderBrush="Transparent">
                                                <ContentPresenter ContentSource="Header"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="BorderBrush" Value="#F5C97B" TargetName="Bd" />
                                                    <Setter Property="Foreground" Value="#F5C97B" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="#E8E2D8" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.ItemContainerStyle>
                    </TabControl>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
