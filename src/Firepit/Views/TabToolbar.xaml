<UserControl x:Class="Firepit.Views.TabToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1612">
    <UserControl.Resources>
        <Style x:Key="ToolbarIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#A89F92" />
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Courier New" />
            <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A211A" TargetName="Bd" />
                                <Setter Property="Foreground" Value="#E8E2D8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#4A413A" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border BorderThickness="0,0,0,1" BorderBrush="#332B22" Padding="6,4">
        <DockPanel LastChildFill="False">
            <Button DockPanel.Dock="Left"
                    ToolTip="Restart this session"
                    Style="{StaticResource ToolbarIconButton}"
                    Click="OnRekindleClick">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconRekindle}"
                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          StrokeThickness="1.3"
                          StrokeLineJoin="Round"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Width="14" Height="14"
                          Margin="0,0,7,0"
                          VerticalAlignment="Center" />
                    <TextBlock Text="Restart" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button DockPanel.Dock="Left"
                    ToolTip="Resume last session (--continue)"
                    Style="{StaticResource ToolbarIconButton}"
                    Click="OnResumeClick">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconResume}"
                          Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          Width="14" Height="14"
                          Margin="0,0,7,0"
                          VerticalAlignment="Center" />
                    <TextBlock Text="Resume" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Border DockPanel.Dock="Left" Width="1" Margin="6,4" Background="#332B22" />
            <!-- Inbox button: always visible, disabled when empty. Counter
                 shows pending unprocessed messages (files in .firepit/inbox/).
                 Click opens a modal that asks Claude to process all of them
                 via the firepit_inbox_list / firepit_inbox_complete MCP
                 tools. The tab-header InboxBadge tracks a different state
                 ("new since this tab was last activated") and clears on
                 activation; this counter only clears as Claude marks
                 messages done. -->
            <Button x:Name="InboxButton"
                    DockPanel.Dock="Left"
                    ToolTip="Process inbox messages with Claude"
                    Style="{StaticResource ToolbarIconButton}"
                    IsEnabled="False"
                    Click="OnInboxClick">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconMail}"
                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          StrokeThickness="1.2"
                          StrokeLineJoin="Round"
                          Width="14" Height="14"
                          Margin="0,0,7,0"
                          VerticalAlignment="Center" />
                    <TextBlock x:Name="InboxLabel"
                               Text="Inbox"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Border DockPanel.Dock="Left" Width="1" Margin="6,4" Background="#332B22" />
            <Button DockPanel.Dock="Left"
                    ToolTip="Open in Explorer"
                    Style="{StaticResource ToolbarIconButton}"
                    Click="OnExplorerClick">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconExplorer}"
                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          StrokeThickness="1.2"
                          StrokeLineJoin="Round"
                          Width="14" Height="14"
                          Margin="0,0,7,0"
                          VerticalAlignment="Center" />
                    <TextBlock Text="Explorer" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button x:Name="ShellButton"
                    DockPanel.Dock="Left"
                    ToolTip="Open external shell here  •  Shift+Click or right-click → run as administrator"
                    Style="{StaticResource ToolbarIconButton}"
                    Click="OnShellClick">
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open shell here" Click="OnShellOpenMenuClick" />
                        <MenuItem Header="Open as administrator" Click="OnShellAdminMenuClick" />
                    </ContextMenu>
                </Button.ContextMenu>
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconShell}"
                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          StrokeThickness="1.3"
                          StrokeLineJoin="Round"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Width="14" Height="14"
                          Margin="0,0,7,0"
                          VerticalAlignment="Center" />
                    <TextBlock Text="Shell" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button DockPanel.Dock="Left"
                    ToolTip="Open this project's .firepit/config.json (creates a commented template if missing)"
                    Style="{StaticResource ToolbarIconButton}"
                    Click="OnConfigureClick">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconGear}"
                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          StrokeThickness="1.2"
                          StrokeLineJoin="Round"
                          Width="14" Height="14"
                          Margin="0,0,7,0"
                          VerticalAlignment="Center" />
                    <TextBlock Text="Configure" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Border DockPanel.Dock="Left" Width="1" Margin="6,4" Background="#332B22" />
            <ItemsControl x:Name="QuickLinks" DockPanel.Dock="Left">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
            <ItemsControl x:Name="Commands" DockPanel.Dock="Left">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </DockPanel>
    </Border>
</UserControl>
