<UserControl x:Class="Firepit.Views.TabToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#15110D">
    <UserControl.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#A89F92" />
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Courier New" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1F1A14" TargetName="Bd" />
                                <Setter Property="Foreground" Value="#E8E2D8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#4A413A" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border BorderThickness="0,0,0,1" BorderBrush="#332B22" Padding="6,4">
        <DockPanel LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="Rekindle"     ToolTip="Rekindle this session"            Style="{StaticResource ToolbarButton}" Click="OnRekindleClick" />
            <Button DockPanel.Dock="Left" Content="Resume Last"  ToolTip="Resume last session (--continue)" Style="{StaticResource ToolbarButton}" Click="OnResumeClick" />
            <Border DockPanel.Dock="Left" Width="1" Margin="6,4" Background="#332B22" />
            <Button DockPanel.Dock="Left" Content="Explorer"     ToolTip="Open in Explorer"                 Style="{StaticResource ToolbarButton}" Click="OnExplorerClick" />
            <Button DockPanel.Dock="Left" Content="Shell"        ToolTip="Open external shell here"         Style="{StaticResource ToolbarButton}" Click="OnShellClick" />
            <Border DockPanel.Dock="Left" Width="1" Margin="6,4" Background="#332B22" />
            <ItemsControl x:Name="QuickLinks" DockPanel.Dock="Left">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </DockPanel>
    </Border>
</UserControl>
