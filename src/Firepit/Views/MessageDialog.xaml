<Window x:Class="Firepit.Views.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Firepit"
        SizeToContent="Height"
        Width="420"
        Background="#1A1612"
        Icon="/firepit.ico"
        BorderBrush="#332B22"
        BorderThickness="1"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="32"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="0"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="MessageButtonBase" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#A89F92" />
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Courier New" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#221C16" TargetName="Bd" />
                                <Setter Property="Foreground" Value="#E8E2D8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2A211A" TargetName="Bd" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MessagePrimaryButton" TargetType="Button" BasedOn="{StaticResource MessageButtonBase}">
            <Setter Property="Background" Value="#2A211A" />
            <Setter Property="Foreground" Value="#F5C97B" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#332821" />
                    <Setter Property="Foreground" Value="#FFD89A" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Caption -->
        <Grid Grid.Row="0" Background="#0A0805">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="CaptionText"
                       Grid.Column="0"
                       Text="Firepit"
                       Foreground="#A89F92"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="14,0,0,0" />
            <Button Grid.Column="1"
                    x:Name="DialogCloseButton"
                    Style="{StaticResource CaptionCloseButton}"
                    Click="OnCloseClick"
                    ToolTip="Close" />
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="20,18,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText"
                       Grid.Row="0"
                       Foreground="#E8E2D8"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="14"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap" />

            <TextBlock x:Name="MessageText"
                       Grid.Row="1"
                       Foreground="#A89F92"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0" />

            <StackPanel x:Name="ButtonRow"
                        Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button x:Name="SecondaryButton"
                        Style="{StaticResource MessageButtonBase}"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        Click="OnSecondaryClick" />
                <Button x:Name="PrimaryButton"
                        Style="{StaticResource MessagePrimaryButton}"
                        IsDefault="True"
                        Click="OnPrimaryClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
