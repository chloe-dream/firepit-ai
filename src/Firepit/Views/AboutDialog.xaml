<Window x:Class="Firepit.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="About Firepit"
        SizeToContent="Height"
        Width="380"
        Background="#1A1612"
        Icon="/firepit.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <shell:WindowChrome.WindowChrome>
        <!-- Patched at runtime — see AboutDialog.xaml.cs. -->
        <shell:WindowChrome
            CaptionHeight="32"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="0"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <!-- Inner border instead of Window.BorderThickness — DWM occasionally clips
         the bottom pixel of a window-level border, leaving the bottom edge of
         the dark frame visually open. An inner border draws inside the client
         area, immune to that. -->
    <Border BorderBrush="#332B22" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="CaptionRow" Height="32" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Caption -->
        <Grid Grid.Row="0" Background="#0A0805">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="About"
                       Foreground="#A89F92"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="{DynamicResource BaseFontSize}"
                       VerticalAlignment="Center"
                       Margin="14,0,0,0" />
            <Button Grid.Column="1"
                    x:Name="DialogCloseButton"
                    Style="{StaticResource CaptionCloseButton}"
                    Width="{DynamicResource DialogCaptionPixelHeight}"
                    Height="{DynamicResource DialogCaptionPixelHeight}"
                    Click="OnCloseClick"
                    ToolTip="Close" />
        </Grid>

        <!-- Body -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    Margin="32,28,32,28">

            <!-- Larger flame mark -->
            <Path Width="64" Height="80"
                  HorizontalAlignment="Center"
                  Stretch="Uniform"
                  Fill="#F5C97B"
                  Data="M 8,1 C 11,5 12,8 11,11 C 13,9 14,12 14,14 C 14,17 11,18 8,18 C 5,18 2,17 2,14 C 2,12 3,9 5,11 C 4,8 5,5 8,1 Z" />

            <TextBlock Text="Firepit"
                       Foreground="#E8E2D8"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="{DynamicResource TitleFontSize}"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,18,0,0" />

            <TextBlock Text="Summon your agents."
                       Foreground="#A89F92"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="{DynamicResource BaseFontSize}"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />

            <TextBlock x:Name="VersionText"
                       Foreground="#8C7A5C"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="{DynamicResource SmallFontSize}"
                       HorizontalAlignment="Center"
                       Margin="0,18,0,0" />

            <TextBlock Text="MIT licensed"
                       Foreground="#8C7A5C"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="{DynamicResource SmallFontSize}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />

            <TextBlock Text="by Chloe Dream"
                       Foreground="#8C7A5C"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="{DynamicResource SmallFontSize}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />

            <Button Content="Close"
                    HorizontalAlignment="Center"
                    Margin="0,22,0,0"
                    MinWidth="100"
                    IsDefault="True"
                    IsCancel="True"
                    Click="OnCloseClick">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#2A211A" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Foreground" Value="#F5C97B" />
                        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Courier New" />
                        <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
                        <Setter Property="Padding" Value="14,7" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#332821" TargetName="Bd" />
                                            <Setter Property="Foreground" Value="#FFD89A" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
    </Border>
</Window>
