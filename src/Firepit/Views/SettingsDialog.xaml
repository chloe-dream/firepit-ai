<Window x:Class="Firepit.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Firepit settings"
        Height="252" Width="540"
        Background="#1A1612"
        Icon="/firepit.ico"
        BorderBrush="#332B22"
        BorderThickness="1"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="32"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="0"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="DialogButtonBase" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#A89F92" />
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Courier New" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#221C16" TargetName="Bd" />
                                <Setter Property="Foreground" Value="#E8E2D8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2A211A" TargetName="Bd" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogPrimaryButton" TargetType="Button" BasedOn="{StaticResource DialogButtonBase}">
            <Setter Property="Background" Value="#2A211A" />
            <Setter Property="Foreground" Value="#F5C97B" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#332821" />
                    <Setter Property="Foreground" Value="#FFD89A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DialogInlineButton" TargetType="Button" BasedOn="{StaticResource DialogButtonBase}">
            <Setter Property="Background" Value="#221C16" />
            <Setter Property="Foreground" Value="#E8E2D8" />
            <Setter Property="Padding" Value="12,6" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A211A" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom dark caption -->
        <Grid Grid.Row="0" Background="#15110D">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Settings"
                       Foreground="#A89F92"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="14,0,0,0" />
            <Button Grid.Column="1"
                    x:Name="DialogCloseButton"
                    Style="{StaticResource CaptionCloseButton}"
                    Click="OnCloseClick"
                    ToolTip="Close" />
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="20,16,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Projects root"
                       Foreground="#E8E2D8"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="13" />

            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="RootBox"
                         Grid.Column="0"
                         Background="#15110D"
                         Foreground="#E8E2D8"
                         BorderBrush="#332B22"
                         BorderThickness="1"
                         CaretBrush="#E8E2D8"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         Padding="8,6" />
                <Button x:Name="BrowseButton"
                        Grid.Column="1"
                        Content="Browse…"
                        Style="{StaticResource DialogInlineButton}"
                        Margin="6,0,0,0"
                        Click="OnBrowseClick" />
            </Grid>

            <TextBlock Grid.Row="2"
                       Text="Other settings live in settings.json — open the file with any editor."
                       Foreground="#8C7A5C"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       FontSize="11"
                       Margin="0,14,0,0"
                       TextWrapping="Wrap" />

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="OpenJsonButton"
                        Content="Open settings.json"
                        Style="{StaticResource DialogButtonBase}"
                        Margin="0,0,8,0"
                        Click="OnOpenJsonClick" />
                <Button x:Name="SaveButton"
                        Content="Save"
                        Style="{StaticResource DialogPrimaryButton}"
                        Margin="0,0,6,0"
                        IsDefault="True"
                        Click="OnSaveClick" />
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Style="{StaticResource DialogButtonBase}"
                        IsCancel="True" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
