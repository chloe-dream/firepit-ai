<Window x:Class="Firepit.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Firepit settings"
        Height="220" Width="540"
        Background="#1A1612"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Projects root"
                   Foreground="#E8E2D8"
                   FontFamily="Cascadia Code, Consolas, Courier New"
                   FontSize="13" />

        <Grid Grid.Row="1" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="RootBox"
                     Grid.Column="0"
                     Background="#15110D"
                     Foreground="#E8E2D8"
                     BorderBrush="#332B22"
                     BorderThickness="1"
                     CaretBrush="#E8E2D8"
                     FontFamily="Cascadia Code, Consolas, Courier New"
                     Padding="6,4" />
            <Button x:Name="BrowseButton"
                    Grid.Column="1"
                    Content="Browse…"
                    Margin="6,0,0,0"
                    Padding="10,4"
                    Background="#2A211A"
                    BorderThickness="0"
                    Foreground="#E8E2D8"
                    Click="OnBrowseClick" />
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="Other settings live in settings.json — open the file with any editor."
                   Foreground="#A89F92"
                   FontFamily="Cascadia Code, Consolas, Courier New"
                   FontSize="11"
                   Margin="0,12,0,0"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="OpenJsonButton" Content="Open settings.json"
                    Padding="10,6" Margin="0,0,8,0"
                    Background="Transparent" Foreground="#A89F92"
                    BorderThickness="0" Click="OnOpenJsonClick" />
            <Button x:Name="SaveButton"   Content="Save"   Padding="14,6" Margin="0,0,6,0"
                    Background="#2A211A" Foreground="#F5C97B" BorderThickness="0"
                    IsDefault="True" Click="OnSaveClick" />
            <Button x:Name="CancelButton" Content="Cancel" Padding="14,6"
                    Background="Transparent" Foreground="#A89F92" BorderThickness="0"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
