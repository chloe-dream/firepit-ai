<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">

    <!-- Common style: square 46x32 like Edge/Terminal -->
    <Style x:Key="CaptionButtonBase" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Foreground" Value="#A89F92" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#221C16" TargetName="Bd" />
                            <Setter Property="Foreground" Value="#E8E2D8" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#2A211A" TargetName="Bd" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CaptionMinimizeButton" TargetType="Button" BasedOn="{StaticResource CaptionButtonBase}">
        <Setter Property="Content">
            <Setter.Value>
                <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                      StrokeThickness="1"
                      Data="M 0,0 L 10,0" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CaptionMaximizeButton" TargetType="Button" BasedOn="{StaticResource CaptionButtonBase}">
        <Setter Property="Content">
            <Setter.Value>
                <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                      StrokeThickness="1"
                      Data="M 0,0 L 10,0 L 10,10 L 0,10 Z" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Restore-down icon (two overlapping squares) — used when window is Maximized -->
    <Style x:Key="CaptionRestoreButton" TargetType="Button" BasedOn="{StaticResource CaptionButtonBase}">
        <Setter Property="Content">
            <Setter.Value>
                <Grid>
                    <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          StrokeThickness="1"
                          Data="M 2,0 L 10,0 L 10,8" />
                    <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          StrokeThickness="1"
                          Data="M 0,2 L 8,2 L 8,10 L 0,10 Z" />
                </Grid>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CaptionCloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButtonBase}">
        <Setter Property="Content">
            <Setter.Value>
                <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                      StrokeThickness="1"
                      Data="M 0,0 L 10,10 M 10,0 L 0,10" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#C42B1C" />
                <Setter Property="Foreground" Value="#FFFFFF" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
