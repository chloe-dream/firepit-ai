<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">

    <!-- Square caption button. Both Width AND Height bound to the caption-bar
         token so the button stays square regardless of how the parent Stack-
         Panel wants to size it. (Stretch alone is flaky inside a horizontal
         StackPanel, which is why the About dialog sets W+H explicitly inline
         and the same is now baked into the style.) -->
    <Style x:Key="CaptionButtonBase" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="{DynamicResource CaptionPixelHeight}" />
        <Setter Property="Height" Value="{DynamicResource CaptionPixelHeight}" />
        <Setter Property="Foreground" Value="#A89F92" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#221C16" TargetName="Bd" />
                            <Setter Property="Foreground" Value="#E8E2D8" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#2A211A" TargetName="Bd" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CaptionMinimizeButton" TargetType="Button" BasedOn="{StaticResource CaptionButtonBase}">
        <Setter Property="Content">
            <Setter.Value>
                <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                      StrokeThickness="1"
                      Data="M 0,0 L 10,0" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CaptionMaximizeButton" TargetType="Button" BasedOn="{StaticResource CaptionButtonBase}">
        <Setter Property="Content">
            <Setter.Value>
                <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                      StrokeThickness="1"
                      Data="M 0,0 L 10,0 L 10,10 L 0,10 Z" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Restore-down icon (two overlapping squares) — used when window is Maximized -->
    <Style x:Key="CaptionRestoreButton" TargetType="Button" BasedOn="{StaticResource CaptionButtonBase}">
        <Setter Property="Content">
            <Setter.Value>
                <Grid>
                    <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          StrokeThickness="1"
                          Data="M 2,0 L 10,0 L 10,8" />
                    <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          StrokeThickness="1"
                          Data="M 0,2 L 8,2 L 8,10 L 0,10 Z" />
                </Grid>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SettingsGearButton" TargetType="Button" BasedOn="{StaticResource CaptionButtonBase}">
        <Setter Property="Content">
            <Setter.Value>
                <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                      Fill="Transparent"
                      StrokeThickness="1.2"
                      StrokeLineJoin="Round"
                      Width="16" Height="16"
                      Stretch="Uniform"
                      Data="M 7,0 L 9,0 L 9.5,2 L 11.5,2.5 L 13,1.3 L 14.7,3 L 13.5,4.5 L 14,6.5 L 16,7 L 16,9 L 14,9.5 L 13.5,11.5 L 14.7,13 L 13,14.7 L 11.5,13.5 L 9.5,14 L 9,16 L 7,16 L 6.5,14 L 4.5,13.5 L 3,14.7 L 1.3,13 L 2.5,11.5 L 2,9.5 L 0,9 L 0,7 L 2,6.5 L 2.5,4.5 L 1.3,3 L 3,1.3 L 4.5,2.5 L 6.5,2 Z M 8,5.5 A 2.5,2.5 0 1 0 8,10.5 A 2.5,2.5 0 1 0 8,5.5 Z" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- App-icon button left of the tabs. Square caption-height tile.
         Hover affordance is path-only (gold brightens to amber); no background
         tile change because a left-edge background highlight reads as a
         selected state, not a hover. -->
    <Style x:Key="AppIconButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="{DynamicResource CaptionPixelHeight}" />
        <Setter Property="Height" Value="{DynamicResource CaptionPixelHeight}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Background="Transparent" SnapsToDevicePixels="True">
                        <Path x:Name="Flame"
                              Width="14" Height="18"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Stretch="Uniform"
                              Fill="#F5C97B"
                              Data="M 8,1 C 11,5 12,8 11,11 C 13,9 14,12 14,14 C 14,17 11,18 8,18 C 5,18 2,17 2,14 C 2,12 3,9 5,11 C 4,8 5,5 8,1 Z" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Fill" Value="#FFD89A" TargetName="Flame" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Fill" Value="#FFE8B8" TargetName="Flame" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- New-tab button: square, full caption height, circular hover halo. -->
    <Style x:Key="NewTabButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="{DynamicResource CaptionPixelHeight}" />
        <Setter Property="Height" Value="{DynamicResource CaptionPixelHeight}" />
        <Setter Property="Foreground" Value="#A89F92" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!-- Inset circular hover halo: smaller than the click-target square so it
                             reads as a tap-target, not as a tile. -->
                        <Ellipse x:Name="Halo"
                                 Width="24" Height="24"
                                 Fill="Transparent"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
                        <Path Stroke="{TemplateBinding Foreground}"
                              StrokeThickness="1.3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0,5 L 10,5 M 5,0 L 5,10" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Fill" Value="#221C16" TargetName="Halo" />
                            <Setter Property="Foreground" Value="#E8E2D8" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Fill" Value="#2A211A" TargetName="Halo" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TabCloseButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Foreground" Value="#A89F92" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="3">
                        <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                              StrokeThickness="1"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0,0 L 7,7 M 7,0 L 0,7" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3A2F26" TargetName="Bd" />
                            <Setter Property="Foreground" Value="#F5C97B" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Close: Template (not Content) so each Button instance gets its own Path —
         a Setter.Value UIElement is shared across instances and disappears from
         the main window once the SettingsDialog also grabs this style. -->
    <Style x:Key="CaptionCloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButtonBase}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <Path Stroke="{TemplateBinding Foreground}"
                              StrokeThickness="1"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0,0 L 10,10 M 10,0 L 0,10" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#C42B1C" TargetName="Bd" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#A02012" TargetName="Bd" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
