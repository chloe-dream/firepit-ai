<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- All icons designed on a 14x14 viewBox.
         Geometry is freezable, so sharing a single resource across many Path
         consumers is safe (unlike sharing a UIElement via Setter.Value). -->

    <!-- Refresh / circular arrow — Rekindle -->
    <Geometry x:Key="IconRekindle">M 12,7 A 5,5 0 1 1 7,2 M 5.5,3.5 L 7,2 L 8.5,3.5</Geometry>

    <!-- Play triangle — Resume Last -->
    <Geometry x:Key="IconResume">M 3.5,2 L 11,7 L 3.5,12 Z</Geometry>

    <!-- Folder with tab — Open in Explorer -->
    <Geometry x:Key="IconExplorer">M 1,4 L 5,4 L 6.5,2.5 L 13,2.5 L 13,11 L 1,11 Z</Geometry>

    <!-- Prompt chevron + underscore — Open external Shell -->
    <Geometry x:Key="IconShell">M 2,4 L 5,7 L 2,10 M 7,11 L 12,11</Geometry>

    <!-- Generic chain link — Quick-links fallback (stroked) -->
    <Geometry x:Key="IconLink">M 4,4 L 6,4 A 2,2 0 0 1 6,8 L 4,8 M 10,4 L 8,4 A 2,2 0 0 0 8,8 L 10,8 M 5,6 L 9,6</Geometry>

    <!-- GitHub Mark (Octocat) — 16x16, filled. Drawn with stretch=Uniform on a
         smaller layout box. Fill rule must be EvenOdd (default) for the inner
         paw cut-out to render correctly. -->
    <Geometry x:Key="IconGitHub">M 8,0 C 3.58,0 0,3.58 0,8 C 0,11.54 2.29,14.53 5.47,15.59 C 5.87,15.66 6.02,15.42 6.02,15.21 C 6.02,15.02 6.01,14.39 6.01,13.72 C 4,14.09 3.48,13.23 3.32,12.78 C 3.23,12.55 2.84,11.84 2.5,11.65 C 2.22,11.5 1.82,11.13 2.49,11.12 C 3.12,11.11 3.57,11.7 3.72,11.94 C 4.44,13.15 5.59,12.81 6.05,12.6 C 6.12,12.08 6.33,11.73 6.56,11.53 C 4.78,11.33 2.92,10.64 2.92,7.58 C 2.92,6.71 3.23,5.99 3.74,5.43 C 3.66,5.23 3.38,4.41 3.82,3.31 C 3.82,3.31 4.49,3.1 6.02,4.13 C 6.66,3.95 7.34,3.86 8.02,3.86 C 8.7,3.86 9.38,3.95 10.02,4.13 C 11.55,3.09 12.22,3.31 12.22,3.31 C 12.66,4.41 12.38,5.23 12.3,5.43 C 12.81,5.99 13.12,6.7 13.12,7.58 C 13.12,10.65 11.25,11.33 9.47,11.53 C 9.76,11.78 10.01,12.26 10.01,13.01 C 10.01,14.08 10,14.94 10,15.21 C 10,15.42 10.15,15.67 10.55,15.59 C 13.71,14.53 16,11.53 16,8 C 16,3.58 12.42,0 8,0 Z</Geometry>

    <!-- Fishbowl glyph — schematic fish (body + tail), filled. 14x14. -->
    <Geometry x:Key="IconFishbowl">M 2,7 C 2,5.5 4,4.5 6.5,4.5 C 9,4.5 10.5,5.5 10.5,7 C 10.5,8.5 9,9.5 6.5,9.5 C 4,9.5 2,8.5 2,7 Z M 10.5,7 L 13.5,4.5 L 13.5,9.5 Z</Geometry>

    <!-- 24x24 spinning arc used during initial session load.
         3/4 circle, drawn so a RotateTransform reads as continuous spin. -->
    <Geometry x:Key="IconSpinnerArc">M 22,12 A 10,10 0 1 1 12,2</Geometry>

</ResourceDictionary>
