<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <!-- V1.13 font-scaling tokens. App.xaml.cs overrides these from settings.json
         before MainWindow loads. Defaults match the historical hardcoded values so
         the Designer surface and a settings-less first run still look right.

         These live in their own ResourceDictionary loaded as the FIRST merged
         dictionary so subsequent merged dictionaries (CaptionButtons.xaml etc.)
         can resolve {StaticResource CaptionPixelHeight} forward references. -->
    <sys:Double x:Key="BaseFontSize">12</sys:Double>
    <sys:Double x:Key="SmallFontSize">11</sys:Double>
    <sys:Double x:Key="MediumFontSize">13</sys:Double>
    <sys:Double x:Key="TitleFontSize">14</sys:Double>
    <sys:Double x:Key="CaptionPixelHeight">36</sys:Double>
    <sys:Double x:Key="DialogCaptionPixelHeight">32</sys:Double>
    <sys:Double x:Key="TabItemPixelHeight">36</sys:Double>
</ResourceDictionary>
