# User-local secrets / config overrides
*.local.json
.env
.env.local

# Firepit + Claude Code — shared config is versioned, runtime/personal is local.
# config.json, .claude/mcp.json, settings.json, commands/, agents/ stay tracked
# (declarative + shareable, no plaintext secrets — only ${cred:...} references).
# The rest below is ephemeral / per-machine / personal.
.firepit/inbox/
.firepit/runs/
# Derived knowledge index (M9) — rebuilt from .firepit/knowledge/*.md anytime.
.firepit/knowledge.db
.firepit/knowledge.db-wal
.firepit/knowledge.db-shm
.claude/*.lock
.claude/agent-memory/

# Test results
TestResults/
*.trx
coverage/
*.coverage
*.coveragexml

# Temp files
*.tmp
*.bak
*~
*.stackdump

# (Inno Setup output now lives under bin/installer — covered by `bin/` above)
